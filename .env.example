# Shelfside — variables de entorno (ejemplo)
# Copiá este archivo a `.env` y completá los valores. No subas `.env` al repositorio.

# --- The Movie Database (películas / series TV) — necesaria para /search ---
# https://www.themoviedb.org/settings/api
# Podés usar la "Clave de la API" (v3) o el "Token de acceso de lectura" (JWT eyJ...).
VITE_TMDB_API_KEY=

# --- IGDB (juegos; requiere app en Twitch) ---
# https://dev.twitch.tv/console/apps — https://api-docs.igdb.com/#account-creation
VITE_TWITCH_CLIENT_ID=
VITE_TWITCH_CLIENT_SECRET=

# --- AniList (anime; muchas consultas públicas sin client secret) ---
# https://anilist.co/settings/developer
VITE_ANILIST_CLIENT_ID=
VITE_ANILIST_CLIENT_SECRET=

# --- MyAnimeList (opcional / v2 crossref) ---
# https://myanimelist.net/apiconfig
VITE_MAL_CLIENT_ID=

# Open Library: normalmente sin clave; respetá límites de tasa en su documentación.
