{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Capability base para Android (sql, fs, dialog, http)",
  "windows": ["main"],
  "platforms": ["android"],
  "permissions": [
    "core:default",
    "allow-android-storage",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://image.tmdb.org/**" },
        { "url": "https://*.tmdb.org/**" },
        { "url": "https://covers.openlibrary.org/**" },
        { "url": "https://*.openlibrary.org/**" }
      ]
    },
    "fs:default",
    "fs:scope-applocaldata-recursive",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "/storage/emulated/0/**" },
        { "path": "/storage/emulated/0/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "/storage/emulated/0/**" },
        { "path": "/storage/emulated/0/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "/storage/emulated/0/**" },
        { "path": "/storage/emulated/0/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "/storage/emulated/0/**" },
        { "path": "/storage/emulated/0/**/*" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$APPDATA/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "/storage/emulated/0/**" },
        { "path": "/storage/emulated/0/**/*" }
      ]
    }
  ]
}
