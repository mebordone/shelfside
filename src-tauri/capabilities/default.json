{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "platforms": ["linux", "windows", "macOS"],
  "remote": {
    "urls": ["http://localhost:1420/**", "http://127.0.0.1:1420/**"]
  },
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://image.tmdb.org/**" },
        { "url": "https://*.tmdb.org/**" },
        { "url": "https://covers.openlibrary.org/**" },
        { "url": "https://*.openlibrary.org/**" }
      ]
    },
    "fs:default",
    "fs:scope-applocaldata-recursive",
    "fs:scope-home-recursive",
    "fs:scope-download-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" },
        { "path": "/mnt/datos/**" },
        { "path": "/mnt/datos/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" },
        { "path": "/mnt/datos/**" },
        { "path": "/mnt/datos/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" },
        { "path": "/mnt/datos/**" },
        { "path": "/mnt/datos/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" },
        { "path": "/mnt/datos/**" },
        { "path": "/mnt/datos/**/*" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$APPDATA/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" },
        { "path": "/mnt/datos/**" },
        { "path": "/mnt/datos/**/*" }
      ]
    }
  ]
}
